@startuml der
hide circle
hide empty method

entity Turno {
    -nroTurno <<PK>>: SERIAL
    -fechaHoraInicio: DATE
    -fechaHoraFin: DATE
    -observaciones: VARCHAR
    -importeTotal: JUS
    -cambioEstado <<FK>>: INTEGER
    -especialidad <<FK>>: INTEGER
    -cobro <<FK>>: INTEGER
    -estadoActual <<FK>>: INTEGER
}

entity CambioEstado {
    -nroCambioEstado <<PK>>: INTEGER
    -fechaHoraInicio: DATE
    -fechaHoraFin: DATE
    -estadoCambioEstado <<FK>>: INTEGER
}

entity Abogado {
    -matricula <<PK>>: VARCHAR
    -nombre: VARCHAR
    -apellido: VARCHAR
    -dni: INTEGER
    -direccion: VARCHAR
    -telefono: INTEGER
    -email: VARCHAR
}

entity Cliente {
    -nroCliente: <<PK>> SERIAL
    -nombre: VARCHAR
    -apellido: VARCHAR
    -dni: INTEGER
    -direccion: VARCHAR
    -telefono: INTEGER
    -email: VARCHAR
}

entity Cobro {
    -monto: INTEGER
    -fechaCobro: DATE
    -tipoCobro <<FK>>: INTEGER
    -importeTotal: INTEGER
    -estado <<FK>>: INTEGER
    -detalleCobro <<FK>>: INTEGER
}

entity Especialidad {
    -idEspecilidad <<PK>>: SERIAL
    -nombre
    -descripcion
}

entity TipoCobro {
    -idTipoCobro <<PK>>: SERIAL
    -nombre
    -descripcion
}

entity Estado {
    -idEstado <<PK>>: SERIAL
    -nombre
    -descripcion
}

entity TurnoXAbogado {
    -idAbogado <<FK>>
    -idTurno <<FK>>
}

entity DetalleCobro {
    - idDetalleCobro <<PK>> : SERIAL
    - idCobro <<FK>> : INTEGER
    - fecha : DATE
    - descripcion : VARCHAR
    - monto : DECIMAL
}

Turno ||--o{ Cobro
Cobro }o--|| TipoCobro
Cobro ||--o{ DetalleCobro

Turno }o--|| Estado : "estadoActual"
Turno ||--o{ CambioEstado : "historial"
CambioEstado }o--|| Estado : "estado aplicado"

Turno ||--o{ TurnoXAbogado
Abogado ||--o{ TurnoXAbogado
Cliente ||--o{ Turno

Abogado ||--|{ Especialidad


@enduml