@startuml Diagrama de Clases
class Turno {
    - nroTurno
    - fechaHoraInicio
    - fechaHoraFin
    - estadoActual:Estado
    - cliente:Cliente
    - abogado:Abogado
    - ultimoCambioEstado:CambioEstado
    - especialidad: especialidad
    - cobro:Cobro
    - observaciones
    + crear()
    + modificar()
}
Turno --> "1..* "Cobro
Turno -> "1" Estado
Turno -->"1..*" CambioEstado
Turno --> "1" Especialidad
Turno -left-> "1"Horario


class Especialidad {
    - nombre
    - descripcion
    + crear()
    + mostrar()
}

class Persona{
    - nombre
    - apellido
    - dni
    - direccion:Direccion
    - telefono
    - email
    + crear()
    + mostrar()
}

Persona -->"1" Direccion

class Cliente {
    - nroCliente
    + crear()
    + mostrar()
}

Cliente -|> Persona
Cliente -->"0..*" Turno


class Abogado {
    - matricula
    + crear()
    + mostrar()

}

Abogado -->"1..*" Especialidad
Abogado -|> Persona
Abogado -->"0..*" Turno

class CambioEstado{
    - fechaHoraInicio
    - fechaHoraFin
    + crear()
    + mostrar()
}

CambioEstado -->"1" Estado

class Cobro {
    - monto
    - fechaCobro
    - tipoCobro:TipoCobro
    - saldoPendiente
    - importeTotal
    - estado:Estado
    - detalleCobro:DetalleCobro
    + calcularSaldoPendiente()
    + calcularImporteTotal()
    + crear()
    + mostrar()

}

Cobro -->"1" TipoCobro
Cobro -->"1..*" DetalleCobro
Cobro -->"1" Estado

class DetalleCobro {
    - fecha
    - descripcion
    - monto
    + crear()
    + mostrar()
}

class TipoCobro {
    - nombre
    - descripcion
    + crear()
    + mostrar()
}

class Estado{
    - ambito
    - valor
    + crear()
    + mostrar()
    + setValor(valor)
    + setAmbito(ambito)
    + getValor()
    + getAmbito()
}

note bottom of Estado : Los metodos de seteo \nse encuentran en esta clase \ny son extensibles a las demas clases

class Direccion{
    - calle
    - numero
    - piso
    - departamento
    - localidad:Localidad
    - provincia
    + crear()
    + mostrar()
}

Direccion -->"1" Localidad

class Localidad{
    - nombre
    - codigoPostal
    + crear()
    + mostrar()
}

class Horario {
    - hora
    - estado
    + crear()
    + mostrar()
}

Horario --> "1"Estado
@enduml